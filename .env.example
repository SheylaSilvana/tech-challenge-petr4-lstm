# Stock ticker (default: PETR4.SA - Petrobras)
TICKER=PETR4.SA

# Modelo
MODEL_PATH=models/lstm_petr4.keras
SCALER_PATH=models/scaler_petr4.joblib
META_PATH=models/meta_petr4.json

# Janela temporal usada no treino (lookback)
SEQUENCE_LENGTH=60

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Monitoring
ENABLE_METRICS=true
